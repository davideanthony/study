# Copia in .env.local e compila con i valori da Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL pubblico canonico del sito (dominio custom in produzione)
# In locale puoi lasciarlo commentato.
# NEXT_PUBLIC_SITE_URL=https://app.tuodominio.it

# Analytics privacy-friendly (Plausible) — vedi README
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=app.tuodominio.it

# Monitoring errori (Sentry) — opzionale
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=

# Server only: eliminazione account e re-indicizzazione PDF (mai esporre al client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
