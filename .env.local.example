# Copia in .env.local e compila con i valori da Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Opzionale: URL pubblico del sito (Open Graph, sitemap, link assoluti)
# NEXT_PUBLIC_SITE_URL=https://stufy.vercel.app

# Analytics privacy-friendly (Plausible) — vedi README
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=stufy.vercel.app

# Monitoring errori (Sentry) — opzionale
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=

# Server only: eliminazione account e re-indicizzazione PDF (mai esporre al client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
